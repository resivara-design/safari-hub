# Copy this file to .env.local and fill in real values for local development.
# Never commit .env.local — it is already excluded via .gitignore.

# Public site URL, used to build Stripe success/cancel redirect links.
NEXT_PUBLIC_SITE_URL=https://safari-hub-sigma.vercel.app

# Stripe (Dashboard > Developers > API keys, in TEST MODE while developing)
STRIPE_SECRET_KEY=sk_test_...

# PayPal (developer.paypal.com > Apps & Credentials, Sandbox app)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...
# Set to "live" only once you switch to a live PayPal app; omit or "sandbox" for testing.
PAYPAL_MODE=sandbox
