# Copy this file to .env.local and fill in real values for local development.
# Never commit .env.local — it is already excluded via .gitignore.

# Public site URL, used to build Stripe success/cancel redirect links.
NEXT_PUBLIC_SITE_URL=https://www.safarihub.uk

# Stripe (Dashboard > Developers > API keys, in TEST MODE while developing)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (Dashboard > Developers > Webhooks > your endpoint)
# Used to verify /api/webhooks/stripe requests actually came from Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (resend.com/api-keys) — sends the order notification email when
# Stripe confirms a payment via the webhook above.
RESEND_API_KEY=re_...

# PayPal removed for now — will be re-added once a PayPal Business account exists.
