# Public site URL, used for absolute URLs in metadata, sitemap and JSON-LD
NEXT_PUBLIC_SITE_URL=

# Stripe (not yet wired up — see lib/payments/ for the integration seam)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — sends the order notification email from the Stripe webhook
RESEND_API_KEY=

# Upstash Redis (Vercel Marketplace integration) — stores product-reminder
# signups. See lib/reminders/.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used to authenticate Vercel Cron calls to /api/cron/reminders.
CRON_SECRET=

# PayPal (not yet wired up — see lib/payments/ for the integration seam)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
